{
  "name": "paklo",
  "version": "0.0.0",
  "license": "AGPL-3.0-later",
  "author": "mburumaxwell",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",

    "changeset": "changeset",
    "packages:version": "changeset version && turbo run packages:version",
    "packages:publish": "changeset publish",

    "extensions-azure:start": "turbo run start --filter=extension-azure-devops...",
    "extensions-azure:build": "turbo run build --filter=extension-azure-devops...",

    "typecheck": "turbo run typecheck",
    "codegen": "turbo run codegen",
    "build": "turbo run build",
    "test": "turbo run test",
    "package": "turbo run package",
    "clean": "turbo run clean && rimraf .turbo"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@svitejs/changesets-changelog-github-compact": "1.2.0",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "turbo": "2.9.9",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.1"
}
